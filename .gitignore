# NVIDIA Showreel - Unified .gitignore

# --- Internal Protocols & Planning (STRICT PRIVACY) ---
protocols/
.codex/
docs/plans/case 03 - implementation.md
docs/plans/houdini_usd_export_guidelines.md

# --- Heavy Work Directories (Project Structure) ---
assets/_external/*
!assets/**/.gitkeep

cache/
refs/
_incoming/
geo/

out/
airflow_gpu_profile_*.json

# --- Source/Project Files (Adobe and other software specific) ---
ae/
ai/
prj/
psd/

hip/

# --- Media & Renders (Heavy) ---
exr/
mp4/
gif/
mov/
png/

# --- File Extensions (Specific Blocklist) ---
# USD (Heavy Binary Crates blocked, ASCII allowed if strictly needed, but guarding general USD)
*.usd
*.usdc
*.usdz

# Houdini
*.hip
*.hipnc
*.hiplc
*.bgeo
*.bgeo.sc
*.vdb
*.abc

# Adobe / Image
*.aep
*.prproj
*.psd
*.ai
*.exr
*.hdr

# --- Local Runtime Overrides ---
configs/*.local.toml
**/configs/*.local.toml

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.env
.venv
env/
venv/
.pytest_cache/
.pytest_tmp/

# --- Tools & System ---
tool/tmp/
tools/tmp/
.idea/
.vscode/
*.code-workspace
.DS_Store
Thumbs.db
